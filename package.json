{
  "name": "material-organizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "service": "node scripts/service.js",
    "service:start": "node scripts/service.js --start",
    "service:stop": "node scripts/service.js --stop",
    "service:restart": "node scripts/service.js --restart",
    "service:status": "node scripts/service.js --status",
    "check": "node --check src/server.js && node --check src/utils.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.11",
    "jsdom": "^24.1.3",
    "marked": "^15.0.12",
    "playwright": "^1.60.0"
  }
}
